{
  "cli": { "version": ">= 12.0.0", "appVersionSource": "remote" },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_API_URL": "https://api.virtualpet.dedyn.io" }
    },
    "production": {
      "distribution": "internal",
      "channel": "production",
      "autoIncrement": true,
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_API_URL": "https://api.virtualpet.dedyn.io" }
    }
  },
  "submit": {}
}